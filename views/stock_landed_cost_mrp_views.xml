<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add "Distribute to MO" button on stock.landed.cost form -->
    <record id="view_stock_landed_cost_mrp_form" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.mrp.distribute</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button string="Distribute to MO"
                        name="%(action_odooer_mrp_landed_cost_wizard)d"
                        type="action"
                        class="btn-primary"
                        attrs="{'invisible': [('state', '!=', 'done')]}"
                        groups="stock.group_stock_manager"/>
            </header>
        </field>
    </record>
</odoo>
